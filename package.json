{
    "name": "netscanner",
    "private": true,
    "version": "1.0.0",
    "description": "AI-infused Network Scanner (Zenmap-like)",
    "author": "Antigravity",
    "main": "electron-main.js",
    "homepage": "./",
    "type": "module",
    "scripts": {
        "dev": "concurrently \"node server.js\" \"vite\"",
        "server": "node server.js",
        "build": "vite build",
        "preview": "vite preview",
        "electron:start": "electron .",
        "electron:pack": "electron-builder --win --x64"
    },
    "build": {
        "appId": "com.antigravity.netscanner",
        "productName": "NetScanner AI",
        "directories": {
            "output": "dist-release"
        },
        "files": [
            "dist/**/*",
            "electron-main.js",
            "server.js",
            "package.json"
        ],
        "win": {
            "target": "nsis"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    },
    "dependencies": {
        "concurrently": "^8.2.2",
        "cors": "^2.8.5",
        "express": "^4.19.2",
        "lucide-react": "^0.395.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "xml2js": "^0.6.2"
    },
    "devDependencies": {
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.1",
        "electron": "^30.0.0",
        "electron-builder": "^24.9.1",
        "vite": "^5.3.1"
    }
}